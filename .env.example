# AIAL Environment Variables
# Copy to .env.local or source via: eval "$(bash infra/scripts/vault-env-export.sh)"
# In local dev, these are populated from Vault dev mode by `make infra-up`.

# === Secrets (from Vault) ===
AIAL_KONG_ADMIN_TOKEN=
AIAL_KEYCLOAK_CLIENT_SECRET=
AIAL_ORACLE_USERNAME=
AIAL_ORACLE_PASSWORD=
AIAL_ORACLE_DSN=

# === Vault Connection (defaults work for local dev) ===
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=root

# === Service URLs (for local dev) ===
KEYCLOAK_URL=http://localhost:8080
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000
WEAVIATE_URL=http://localhost:8081
CERBOS_URL=http://localhost:3592
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://aial:aial@localhost:5432/aial
