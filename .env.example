# AIAL Environment Variables
# Copy to .env.local or source via: eval "$(bash infra/scripts/vault-env-export.sh)"
# In local dev, these are populated from Vault dev mode by `make infra-up`.

# === Secrets (from Vault) ===
AIAL_KONG_ADMIN_TOKEN=
AIAL_KEYCLOAK_CLIENT_SECRET=
AIAL_ORACLE_USERNAME=
AIAL_ORACLE_PASSWORD=
# Example Oracle Free DSN:
# AIAL_ORACLE_DSN=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=FREE)))
AIAL_ORACLE_DSN=

# === Vault Connection (defaults work for local dev) ===
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=root

# === Service URLs (for local dev) ===
KEYCLOAK_URL=http://localhost:8080
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000
WEAVIATE_URL=http://localhost:8081
CERBOS_URL=http://localhost:3592
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://aial:aial@localhost:5432/aial
AIAL_CONFIG_CATALOG_PERSISTENCE=postgres
AIAL_CONFIG_CATALOG_SCHEMA=public
AIAL_SEMANTIC_RUNTIME=cube
AIAL_SEED_ORACLE_SAMPLE=true
AIAL_CUBE_API_URL=http://localhost:4000/cubejs-api/v1
AIAL_CUBE_MODEL_DIR=infra/cube/model
AIAL_CUBE_TIMEOUT_SECONDS=8
CUBEJS_API_SECRET=aial-cube-dev-secret
CUBEJS_DB_TYPE=oracle
CUBEJS_DB_HOST=oracle-free
CUBEJS_DB_PORT=1521
CUBEJS_DB_NAME=FREE
CUBEJS_DB_USER=system
CUBEJS_DB_PASS=oracle
CUBEJS_PG_SQL_PORT=15432
CUBEJS_SQL_USER=cube
CUBEJS_SQL_PASSWORD=cube
AIAL_LOCAL_AUTH_SECRET=aial-local-dev-secret
AIAL_LOCAL_ADMIN_USERNAME=admin
AIAL_LOCAL_ADMIN_PASSWORD=admin123!
AIAL_LOCAL_ADMIN_RESET_ON_START=false
AIAL_LOCAL_ADMIN_EMAIL=admin@aial.local
AIAL_LOCAL_ADMIN_DEPARTMENT=engineering
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
